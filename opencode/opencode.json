{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "plugin": ["opencode-claude-auth"],
  // TODO: Configure these
  // "model": "openai/gpt-5.3-codex-spark",
  "small_model": "anthropic/claude-haiku-4-5", // title gen, lightweight tasks
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-next:q4_K_M": {
          "_launch": true,
          "name": "qwen3-coder-next:q4_K_M"
        },
        "qwen3:8b": {
          "_launch": true,
          "name": "qwen3:8b"
        }
      }
    }
  },
  "default_agent": "plan",
  "agent": {
    "build": {
      // "model": "ollama/qwen3-coder-next:q4_K_M"
      // "model": "anthropic/claude-haiku-4-5",
      // "model": "anthropic/claude-sonnet-4-6",
      "model": "opencode/claude-sonnet-4-6",
      // "model": "opencode/gpt-5.3-codex-spark",
      "permission": {
        "bash": {
          "git commit*": "deny",
          "git stash*": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git merge*": "deny",
          "git reset*": "deny"
        }
      }
    },
    "explore": {
      // "model": "anthropic/claude-sonnet-4-6",
      "model": "opencode/claude-sonnet-4-6",
      "mode": "subagent"
    },
    "plan": {
      // "model": "anthropic/claude-opus-4-6",
      "model": "opencode/claude-opus-4-6",
      // "model": "opencode/gpt-5.4",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      },
      "permission": {
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "tree *": "allow",
          "wc *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "pnpm test*": "ask",
          "docker compose logs *": "allow"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "git": "ask"
        }
      }
    },
    "git": {
      "model": "anthropic/claude-sonnet-4-6",
      // "model": "opencode/gpt-5.3-codex-spark",
      "mode": "subagent",
      "description": "Git and GitHub operations agent (stage, commit, push, create/update PRs, read PR state). ONLY invoke this agent when explicitly asked to perform a git operation. Since this agent cannot read any files or code on its own, the calling agent must provide all necessary context in the prompt (e.g. file paths, diff content, commit message, PR title/body, branch names, etc.).",
      "tools": {
        "write": false,
        "edit": false,
        "patch": false,
        "glob": false,
        "grep": false,
        "read": false
      },
      "permission": {
        "bash": {
          "*": "deny",
          "git *": "allow",
          "gh pr *": "allow"
        },
        "task": {
          "*": "deny"
        }
      }
    }
  }
}
